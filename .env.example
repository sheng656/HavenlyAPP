# GitHub Models API token for the AI chat companion ("岛岛")
# Obtain a token from: https://github.com/settings/tokens
# Ensure the token has access to GitHub Models (the `models` permission is required).
# Without this token the app falls back to curated mock responses.
VITE_GITHUB_TOKEN=your_github_token_here

# Optional: override GitHub Models endpoint/model
VITE_GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference/chat/completions
VITE_GITHUB_MODEL=gpt-4o-mini

# Optional Firebase cloud sync (disabled by default)
# Set VITE_ENABLE_FIREBASE_SYNC=true and fill values below to enable.
VITE_ENABLE_FIREBASE_SYNC=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
